# Server Configuration
APP_NAME="NexusAI Project Intelligence Platform"
DEBUG=True

# API & Credentials (Provide your own keys here)
GEMINI_API_KEY="your_gemini_api_key_here"
OPENAI_API_KEY="your_openai_api_key_here"
PINECONE_API_KEY="your_pinecone_api_key_here"
PINECONE_INDEX_NAME="your_pinecone_index_name_here"
JWT_SECRET_KEY="your_jwt_secret_key_here"

# LangSmith / LangChain Tracing Configurations
LANGSMITH_API_KEY="your_langsmith_api_key_here"
LANGSMITH_PROJECT="your_langsmith_project_name_here"

# Database Configuration (falls back to local SQLite if left at default/localhost postgres)
POSTGRES_URL="postgresql://user:pass@localhost:5432/pidb"
REDIS_URL="redis://localhost:6379/0"
RABBITMQ_URL="amqp://guest:guest@localhost:5672//"
